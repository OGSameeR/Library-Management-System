#include <iostream>
#include <vector>
#include <string>
#include <algorithm>
#include <iomanip>

using namespace std;

// --- Book Class ---
class Book {
private:
    int bookID;
    string title;
    string author;
    bool isIssued;

public:
    Book(int id, string t, string a) : bookID(id), title(t), author(a), isIssued(false) {}

    int getID() const { return bookID; }
    string getTitle() const { return title; }
    string getAuthor() const { return author; }
    bool getIssuedStatus() const { return isIssued; }

    void issueBook() { isIssued = true; }
    void returnBook() { isIssued = false; }

    void displayBook() const {
        cout << left << setw(10) << bookID 
             << setw(30) << title 
             << setw(25) << author 
             << setw(15) << (isIssued ? "Issued" : "Available") << endl;
    }
};

// --- Member Class ---
class Member {
private:
    int memberID;
    string name;
    vector<int> borrowedBookIDs; // Tracks IDs of books currently borrowed

public:
    Member(int id, string n) : memberID(id), name(n) {}

    int getID() const { return memberID; }
    string getName() const { return name; }
    
    void borrowBook(int bookID) {
        borrowedBookIDs.push_back(bookID);
    }

    void returnBook(int bookID) {
        auto it = find(borrowedBookIDs.begin(), borrowedBookIDs.end(), bookID);
        if (it != borrowedBookIDs.end()) {
            borrowedBookIDs.erase(it);
        }
    }

    void displayMember() const {
        cout << left << setw(12) << memberID << setw(25) << name << "Books Borrowed: ";
        if (borrowedBookIDs.empty()) {
            cout << "None";
        } else {
            for (int id : borrowedBookIDs) {
                cout << "[" << id << "] ";
            }
        }
        cout << endl;
    }
};

// --- Library Management System (Core Engine) ---
class LibrarySystem {
private:
    vector<Book> books;
    vector<Member> members;

    // Helper to transform strings to lowercase for case-insensitive searching
    string toLowerCase(string str) {
        transform(str.begin(), str.end(), str.begin(), ::tolower);
        return str;
    }

public:
    // Helper function to seed an initial member cleanly
    void seedMember(int id, string name) {
        members.push_back(Member(id, name));
    }

    void addBook() {
        int id;
        string title, author;
        cout << "\n--- Add New Book ---\n";
        cout << "Enter Book ID: ";
        cin >> id;
        cin.ignore();
        cout << "Enter Book Title: ";
        getline(cin, title);
        cout << "Enter Author Name: ";
        getline(cin, author);

        books.push_back(Book(id, title, author));
        cout << "Book added successfully!\n";
    }

    void registerMember() {
        int id;
        string name;
        cout << "\n--- Register Member ---\n";
        cout << "Enter Member ID: ";
        cin >> id;
        cin.ignore();
        cout << "Enter Member Name: ";
        getline(cin, name);

        members.push_back(Member(id, name));
        cout << "Member registered successfully!\n";
    }

    void issueBook() {
        int bookID, memberID;
        cout << "\n--- Issue Book ---\n";
        cout << "Enter Member ID: ";
        cin >> memberID;
        cout << "Enter Book ID: ";
        cin >> bookID;

        // Find Member
        Member* targetMember = nullptr;
        for (auto &m : members) {
            if (m.getID() == memberID) {
                targetMember = &m;
                break;
            }
        }

        // Find Book
        Book* targetBook = nullptr;
        for (auto &b : books) {
            if (b.getID() == bookID) {
                targetBook = &b;
                break;
            }
        }

        if (!targetMember) {
            cout << "Error: Member ID not found!\n";
            return;
        }
        if (!targetBook) {
            cout << "Error: Book ID not found!\n";
            return;
        }
        if (targetBook->getIssuedStatus()) {
            cout << "Error: Book is already issued to someone else!\n";
            return;
        }

        // Complete Transaction
        targetBook->issueBook();
        targetMember->borrowBook(bookID);
        cout << "Book successfully issued to " << targetMember->getName() << "!\n";
    }

    void returnBook() {
        int bookID, memberID;
        cout << "\n--- Return Book ---\n";
        cout << "Enter Member ID: ";
        cin >> memberID;
        cout << "Enter Book ID: ";
        cin >> bookID;

        Member* targetMember = nullptr;
        for (auto &m : members) {
            if (m.getID() == memberID) {
                targetMember = &m;
                break;
            }
        }

        Book* targetBook = nullptr;
        for (auto &b : books) {
            if (b.getID() == bookID) {
                targetBook = &b;
                break;
            }
        }

        if (targetMember && targetBook && targetBook->getIssuedStatus()) {
            targetBook->returnBook();
            targetMember->returnBook(bookID);
            cout << "Book successfully returned!\n";
        } else {
            cout << "Error: Direct conflict with data. Check IDs or status again.\n";
        }
    }

    void searchBooks() {
        int searchChoice;
        cout << "\n--- Search Books ---\n";
        cout << "1. Search by Title\n2. Search by Author\nSelect option: ";
        cin >> searchChoice;
        cin.ignore();

        string query;
        cout << "Enter search query: ";
        getline(cin, query);
        query = toLowerCase(query);

        cout << "\n" << left << setw(10) << "Book ID" << setw(30) << "Title" << setw(25) << "Author" << setw(15) << "Status" << endl;
        cout << string(80, '-') << endl;

        bool found = false;
        for (const auto &b : books) {
            if (searchChoice == 1 && toLowerCase(b.getTitle()).find(query) != string::npos) {
                b.displayBook();
                found = true;
            } else if (searchChoice == 2 && toLowerCase(b.getAuthor()).find(query) != string::npos) {
                b.displayBook();
                found = true;
            }
        }
        if (!found) cout << "No matches found.\n";
    }

    void displayAllBooks() {
        cout << "\n" << left << setw(10) << "Book ID" << setw(30) << "Title" << setw(25) << "Author" << setw(15) << "Status" << endl;
        cout << string(80, '-') << endl;
        for (const auto &b : books) b.displayBook();
    }
};

// --- Main Application UI Loop ---
int main() {
    LibrarySystem lib;
    int choice;

    // Seed data with a generic placeholder name so the application isn't completely empty on launch
    lib.seedMember(1, "John Doe");
    
    do {
        cout << "\n=================================";
        cout << "\n    LIBRARY MANAGEMENT SYSTEM";
        cout << "\n=================================";
        cout << "\n1. Add New Book";
        cout << "\n2. Register New Member";
        cout << "\n3. Issue a Book";
        cout << "\n4. Return a Book";
        cout << "\n5. Search for a Book";
        cout << "\n6. List All Books";
        cout << "\n7. Exit";
        cout << "\n=================================";
        cout << "\nSelect choice (1-7): ";
        cin >> choice;

        switch (choice) {
            case 1: lib.addBook(); break;
            case 2: lib.registerMember(); break;
            case 3: lib.issueBook(); break;
            case 4: lib.returnBook(); break;
            case 5: lib.searchBooks(); break;
            case 6: lib.displayAllBooks(); break;
            case 7: cout << "\nExiting System. Happy Reading!\n"; break;
            default: cout << "\nInvalid Selection! Try again.\n";
        }
    } while (choice != 7);

    return 0;
}
